class MultiSystemVisualization(Scene):
    def construct(self):
        # Titles
        title_a = Text("Fisher Kolmogorov - 1Node").scale(0.5)
        title_b = Text("Fisher Kolmogorov - 2Node").scale(0.5)
        title_c = Text("Heterodimer - 1Node").scale(0.5)
        title_d = Text("Heterodimer - 2Node").scale(0.5)

        # Position titles
        title_a.to_corner(UL)
        title_b.to_corner(UR)
        title_c.to_corner(DL).shift(UP * 0.5, RIGHT * 0.5)
        title_d.to_corner(DR).shift(UP * 0.5, LEFT * 0.5)

        titles = VGroup(title_a, title_b, title_c, title_d)
        self.play(Write(titles))

        # Equations
        eq_a = MathTex(r"\frac{dc_1}{dt} = \alpha c_1 (1 - c_1)").scale(0.5)
        eq_b = MathTex(r"\frac{dc_1}{dt} = -(c_1 - c_2) + \alpha c_1 (1 - c_1)").scale(0.5)
        eq_c = MathTex(r"\frac{d\tilde{p}_1}{dt} = -(k_{1\tilde{}} v_1) + (k_{12} u_1 v_1)").scale(0.5)
        eq_d = MathTex(r"\frac{d\tilde{p}_1}{dt} = -(-v_1 + v_2) - (k_{1\tilde{}} v_1) + (k_{12} u_1 v_1)").scale(0.5)

        # Position equations
        eq_a.next_to(title_a, DOWN, buff=0.5)
        eq_b.next_to(title_b, DOWN, buff=0.5)
        eq_c.next_to(title_c, UP, buff=0.5).shift(RIGHT)
        eq_d.next_to(title_d, UP, buff=0.5).shift(LEFT)

        equations = VGroup(eq_a, eq_b, eq_c, eq_d)
        self.play(Write(equations))
        self.wait()

        # Circles for A
        circle_a = Circle(radius=1, color=WHITE, stroke_width=0).scale(0.8).set_fill(WHITE, opacity=1).next_to(eq_a, DOWN, buff=0.3)

        # Two connected circles for B
        circle_b1 = Circle(radius=1, color=WHITE, stroke_width=0).scale(0.5).set_fill(WHITE, opacity=1).shift(LEFT * 0.7)
        circle_b2 = Circle(radius=1, color=WHITE, stroke_width=0).scale(0.5).set_fill(WHITE, opacity=1).shift(RIGHT * 0.7)
        line_b = Line(circle_b1.get_right(), circle_b2.get_left(), color=WHITE)
        group_b = VGroup(circle_b1, circle_b2, line_b).next_to(circle_a, RIGHT, buff = 6)

        # Single circle for C
        circle_c = Circle(radius=1, color=WHITE, stroke_width=0).scale(0.8).set_fill(WHITE, opacity=1).next_to(circle_a, DOWN, buff =0.3)

        # Two connected circles for D
        circle_d1 = Circle(radius=1, color=WHITE, stroke_width=0).scale(0.5).set_fill(WHITE, opacity=1).shift(LEFT * 0.7)
        circle_d2 = Circle(radius=1, color=WHITE, stroke_width=0).scale(0.5).set_fill(WHITE, opacity=1).shift(RIGHT * 0.7)
        line_d = Line(circle_d1.get_right(), circle_d2.get_left(), color=WHITE)
        group_d = VGroup(circle_d1, circle_d2, line_d).next_to(circle_c, RIGHT, buff = 6)

        self.add(circle_a, group_b, circle_c, group_d)

        # Concentration displays
        conc_a = DecimalNumber(0, num_decimal_places=2).scale(0.5).next_to(circle_a, RIGHT, buff=0.5)
        conc_b1 = DecimalNumber(0, num_decimal_places=2).scale(0.5).next_to(circle_b1, LEFT, buff=0.5)
        conc_b2 = DecimalNumber(0, num_decimal_places=2).scale(0.5).next_to(circle_b2, RIGHT, buff=0.5)
        conc_c = DecimalNumber(0, num_decimal_places=2).scale(0.5).next_to(circle_c, RIGHT, buff=0.5)
        conc_d1 = DecimalNumber(0, num_decimal_places=2).scale(0.5).next_to(circle_d1, LEFT, buff=0.5)
        conc_d2 = DecimalNumber(0, num_decimal_places=2).scale(0.5).next_to(circle_d2, RIGHT, buff=0.5)

        self.add(conc_a, conc_b1, conc_b2, conc_c, conc_d1, conc_d2)

        # Time display in the center
        time_display = DecimalNumber(0, num_decimal_places=1, color=WHITE).scale(1.5)
        self.add(time_display)

        # Animate changes
        for t, c1, b1, b2, h1, d1, d2 in zip(LINSPACE, sol_fk1, sol_fk2_1, sol_fk2_2, sol_het1, sol_het2_1, sol_het2_2):
            # Update colors and concentrations
            new_color_a = interpolate_color(WHITE, RED, c1)
            new_color_b1 = interpolate_color(WHITE, RED, b1)
            new_color_b2 = interpolate_color(WHITE, RED, b2)
            new_color_c = interpolate_color(WHITE, RED, h1)
            new_color_d1 = interpolate_color(WHITE, RED, d1)
            new_color_d2 = interpolate_color(WHITE, RED, d2)

            self.play(
                circle_a.animate.set_fill(new_color_a),
                circle_b1.animate.set_fill(new_color_b1),
                circle_b2.animate.set_fill(new_color_b2),
                circle_c.animate.set_fill(new_color_c),
                circle_d1.animate.set_fill(new_color_d1),
                circle_d2.animate.set_fill(new_color_d2),
                conc_a.animate.set_value(c1),
                conc_b1.animate.set_value(b1),
                conc_b2.animate.set_value(b2),
                conc_c.animate.set_value(h1),
                conc_d1.animate.set_value(d1),
                conc_d2.animate.set_value(d2),
                time_display.animate.set_value(t),
                run_time=0.3
            )

        self.wait(2)

