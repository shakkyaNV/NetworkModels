def fun_FK(t, y, L):
    x = len(y)
    k0 = 1.0
    k1 = 0.5
    k12 = 0.5
    k1_tilda = 0.5
    
    # assigning y's to dict; to be called later
    res = {}
    funs = {}
    for index in range(int(x/2)): 
        node = index + 1          # I don't like 0 indexing. Node is what we wan't to loop. index for accessing y
        res[f"u_{node}"] = y[index*2]
        res[f"v_{node}"] = y[index*2 + 1]
    
    for index in range(int(x/2)): 
        node = index + 1          # I don't like 0 indexing. Node is what we wan't to loop. index for accessing y
        
        sum_p = 0
        sum_p_tilda = 0
        
        for col in range(int(x/2)):
            j = col + 1            # I don't like 0 indexing. J is what we want in Sigma Sum. col for accesing L: laplacian
            sum_p       += res[f"u_{j}"] * L[index][col]
            sum_p_tilda += res[f"v_{j}"] * L[index][col]
            
        funs[f"fu_{node}"] = (-1 * sum_p)          + k0 - (k1 * res[f"u_{node}"])       - (k12 * res[f"u_{node}"] * res[f"v_{node}"])
        funs[f"fv_{node}"] = (-1 * sum_p_tilda)    - (k1_tilda * res[f"v_{node}"]) + (k12 * res[f"u_{node}"] * res[f"v_{node}"])
    return list(funs.values())


